# Node modules
node_modules/
*.log
.env
.DS_Store
*.pem

# Cookies (dados sensiveis)
cookies/*
!cookies/incoming/
!cookies/archive/
!cookies/rejected/
cookies/incoming/*
cookies/archive/*
cookies/rejected/*
!cookies/incoming/.gitkeep
!cookies/archive/.gitkeep
!cookies/rejected/.gitkeep

# Backups
backup_*/
*.bkp

# Arquivos temporarios do sistema
Thumbs.db
*.tmp
temp-*

# PM2 logs (se existirem)
*.pm2.log

# Editor
.vscode/
.idea/

cookies/*.txt
.env
yt-dlp.exe

# Cookie Sync local secrets and temporary files
tools/cookie-sync/cookie-sync.config.json
tools/cookie-sync/*.tmp
tools/cookie-sync/temp/
tools/cookie-sync/*.cookies.txt
scripts/cookie-sync/cookie-sync.env

# yt-dlp manager local env
scripts/yt-dlp-manager/yt-dlp-manager.env

# Cookie refresh queue runtime state
data/*
!data/.gitkeep

# Cookie Agent local secrets and state
tools/cookie-agent/cookie-agent.config.json
tools/cookie-agent/agent-state.json

# Runtime logs
logs/cookie-sync/*
logs/yt-dlp-manager/*
logs/cookie-agent/*
!logs/cookie-sync/.gitkeep
!logs/yt-dlp-manager/.gitkeep
!logs/cookie-agent/.gitkeep
