    try {
        console.log('?? Enviando email de teste...');
        await emailAlerts.liveUp('teste-id', 'Teste do sistema V3 - NeoNews Live Monitor');
        res.json({ success: true, message: 'Email de teste enviado! Verifique sua caixa de entrada.' });
