// Testar cookie atual
app.post('/admin/test-cookie', async (req, res) => {
    const mainPath = path.join(cookiesDir, 'main.txt');
    const backupPath = path.join(cookiesDir, 'backup.txt');
    const cookiePath = fs.existsSync(mainPath) ? mainPath : (fs.existsSync(backupPath) ? backupPath : null);
    
    if (!cookiePath) {
        return res.json({ 
            success: false, 
            valid: false, 
            error: 'Nenhum cookie encontrado. Fa?a upload em /admin/cookie' 
        });
    }
    
    const stats = fs.statSync(cookiePath);
    const ytCmd = process.platform === 'win32' ? '.\\yt-dlp.exe' : 'yt-dlp';
    const testUrl = 'https://www.youtube.com/watch?v=rdHcRsSCBiU';
    const command = `${ytCmd} --cookies "${cookiePath}" -g --format best "${testUrl}"`;
    
    console.log('?? Testando cookie:', cookiePath);
    
    try {
        const { stdout, stderr } = await execPromise(command, { timeout: 30000 });
        const hlsUrl = stdout.trim();
        
        if (hlsUrl.includes('.m3u8') || hlsUrl.includes('manifest')) {
            res.json({ 
                success: true,
                valid: true, 
                message: 'Cookie valido',
                cookieFile: path.basename(cookiePath),
                cookieSize: stats.size,
                hlsExtracted: true
            });
        } else {
            res.json({ 
                success: false,
                valid: false, 
                error: 'Cookie nao extraiu HLS',
                cookieFile: path.basename(cookiePath)
            });
        }
    } catch (error) {
        res.json({ 
            success: false,
            valid: false, 
            error: error.message,
            cookieFile: path.basename(cookiePath),
            cookieSize: stats.size
        });
    }
});

// Status detalhado dos monitores
app.get('/admin/monitors', (req, res) => {
    const monitors = [];
    
    if (converter && converter.liveCache) {
        for (const [url, data] of converter.liveCache.entries()) {
            const monitorInfo = data.monitor ? data.monitor.getLiveInfo() : {};
            monitors.push({
                videoId: data.videoId,
                url: url,
                status: data.isLive ? 'online' : 'offline',
                clients: data.hits || 1,
                createdAt: data.createdAt,
                lastCheck: monitorInfo.lastCheck || data.lastCheck,
                failCount: monitorInfo.failCount || 0,
                cookieActive: monitorInfo.cookieActive !== undefined ? monitorInfo.cookieActive : !!monitorInfo.cookieSwitches,
                cookieSwitches: monitorInfo.cookieSwitches || 0
            });
        }
    }
    
    res.json({
        totalMonitors: monitors.length,
        monitors: monitors,
        timestamp: new Date().toISOString()
    });
});

// Fun??o auxiliar
function formatUptime(seconds) {
    const hours = Math.floor(seconds / 3600);
    const minutes = Math.floor((seconds % 3600) / 60);
    const secs = Math.floor(seconds % 60);
    return `${hours}h ${minutes}m ${secs}s`;
}

