# Servidor
PORT=3002
NODE_ENV=development

# 🔥 OBRIGATÓRIO - JWT Secret para autenticação
JWT_SECRET=seu-segredo-super-secreto-aqui-muito-grande

# 🔥 OBRIGATÓRIO - Senha do admin
